{
	"name": "requery",
	"version": "0.1.0",
	"description": "A jQuery 4 plugin for reactive state and declarative DOM binding inspired by React and Vue.",
	"main": "dist/requery.umd.js",
	"module": "dist/requery.esm.js",
	"scripts": {
		"build": "vite build",
		"dev": "vite build --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"docs:dev": "cd docs && npm run dev",
		"docs:build": "cd docs && npm run build"
	},
	"keywords": [
		"jquery",
		"jquery-plugin",
		"reactive",
		"state",
		"dom-binding"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/peterbenoit/requery.git"
	},
	"homepage": "https://github.com/peterbenoit/requery#readme",
	"bugs": {
		"url": "https://github.com/peterbenoit/requery/issues"
	},
	"peerDependencies": {
		"jquery": ">=4.0.0"
	},
	"devDependencies": {
		"happy-dom": "^20.6.3",
		"jquery": "^4.0.0",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	}
}
